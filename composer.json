{
  "name": "doc2k/doccheck-access",
  "type": "typo3-cms-extension",
  "description": "DocCheck Access is a lightweight TYPO3 extension that provides DocCheck OAuth authentication for frontend access.",
  "version": "1.0.3",
  "license": "GPL-3.0-or-later",
  "require": {
    "php": ">=8.0",
    "typo3/cms-core": "^11.5 || ^12.4 || ^13.4 || ^14.0",
    "typo3/cms-frontend": "^11.5 || ^12.4 || ^13.4 || ^14.0"
  },
  "autoload": {
    "psr-4": {
      "Doc2k\\DoccheckAccess\\": "Classes/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "doccheck_access"
    }
  }
}
